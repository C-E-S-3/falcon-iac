---
# CrowdStrike Falcon DLP -- web locations (current state)
# Generated: {{ ansible_date_time.iso8601 }}
#
# Copy entries you want under IaC management into your
# {{ falcon_dlp_policies_dir }}/web_locations/ directory.
{%- if _existing_web_locations_system | length > 0 %}
#
# System-defined web locations ({{ _existing_web_locations_system | length }}) are protected and NOT exported:
{%- for w in _existing_web_locations_system | sort(attribute='name') %}
#   - {{ w.name }}
{%- endfor %}
{%- endif %}

falcon_dlp_web_locations:
{%- if _existing_web_locations_user | length == 0 %} []
{%- endif %}
{%- for w in _existing_web_locations_user | sort(attribute='name') %}
  - name: {{ w.name | to_json }}
    description: {{ w.description | default('') | to_json }}
    urls:
{%- for u in w.urls | default([]) %}
      - fqdn: {{ u.fqdn | default('') | to_json }}
        path: {{ u.path | default('/*') | to_json }}
{%- endfor %}
{%- endfor %}
