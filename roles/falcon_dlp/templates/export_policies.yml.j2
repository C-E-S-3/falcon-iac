---
# CrowdStrike Falcon DLP -- policies (current state)
# Generated: {{ ansible_date_time.iso8601 }}
#
# Copy entries you want under IaC management into your
# {{ falcon_dlp_policies_dir }}/policies/ directory.
# Classification IDs have been resolved back to names. Entries marked
# "# UNKNOWN_ID:..." reference a classification that no longer exists.
{% if _truly_system_policies | length > 0 %}
#
# System-defined policies ({{ _truly_system_policies | length }}) are protected and NOT exported:
{% for p in _truly_system_policies | sort(attribute='name') %}
#   - {{ p.name }}
{% endfor %}
{% endif %}

{% if _for_export_policies | length == 0 %}
falcon_dlp_policies: []
{% else %}
falcon_dlp_policies:
{% for p in _for_export_policies | sort(attribute='name') %}
  - name: {{ p.name | to_json }}
    description: {{ p.description | default('') | to_json }}
    enabled: {{ (p.enabled | default(true)) | to_json }}
    platform: {{ p.platform | default('win') | to_json }}
    classifications:
{% for cid in p.classifications | default([]) %}
{% if cid in (_classifications_by_id | default({})) %}
      - {{ _classifications_by_id[cid] | to_json }}
{% else %}
      - {{ ('UNKNOWN_ID:' ~ cid) | to_json }}
{% endif %}
{% endfor %}
    host_groups: {{ p.host_groups | default([]) | to_json }}
{% endfor %}
{% endif %}
