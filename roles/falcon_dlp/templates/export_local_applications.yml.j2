---
# CrowdStrike Falcon DLP -- local applications (current state)
# Generated: {{ ansible_date_time.iso8601 }}
#
# Copy entries you want under IaC management into your
# {{ falcon_dlp_policies_dir }}/local_applications/ directory.
{% if _truly_system_local_apps | length > 0 %}
#
# System-defined local applications ({{ _truly_system_local_apps | length }}) are protected and NOT exported:
{% for a in _truly_system_local_apps | sort(attribute='name') %}
#   - {{ a.name }}
{% endfor %}
{% endif %}

{% if _for_export_local_apps | length == 0 %}
falcon_dlp_local_applications: []
{% else %}
falcon_dlp_local_applications:
{% for a in _for_export_local_apps | sort(attribute='name') %}
  - name: {{ a.name | to_json }}
    description: {{ a.description | default('') | to_json }}
    platform: {{ a.platform | default('win') | to_json }}
    paths:
{% for p in a.paths | default([]) %}
      - {{ p | to_json }}
{% endfor %}
    file_names:
{% for f in a.file_names | default([]) %}
      - {{ f | to_json }}
{% endfor %}
    sha256_hashes:
{% for h in a.sha256_hashes | default([]) %}
      - {{ h | to_json }}
{% endfor %}
{% endfor %}
{% endif %}
