---
# CrowdStrike Falcon DLP -- cloud applications (current state)
# Generated: {{ ansible_date_time.iso8601 }}
#
# Copy entries you want under IaC management into your
# {{ falcon_dlp_policies_dir }}/cloud_applications/ directory.
{%- if _existing_cloud_apps_system | length > 0 %}
#
# System-defined cloud applications ({{ _existing_cloud_apps_system | length }}) are protected and NOT exported:
{%- for c in _existing_cloud_apps_system | sort(attribute='name') %}
#   - {{ c.name }}
{%- endfor %}
{%- endif %}

falcon_dlp_cloud_applications:
{%- if _existing_cloud_apps_user | length == 0 %} []
{%- endif %}
{%- for c in _existing_cloud_apps_user | sort(attribute='name') %}
  - name: {{ c.name | to_json }}
    description: {{ c.description | default('') | to_json }}
    urls:
{%- for u in c.urls | default([]) %}
      - fqdn: {{ u.fqdn | default('') | to_json }}
        path: {{ u.path | default('/*') | to_json }}
{%- endfor %}
{%- endfor %}
