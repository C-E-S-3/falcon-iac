---
# CrowdStrike Falcon DLP -- local application groups (current state)
# Generated: {{ ansible_date_time.iso8601 }}
#
# Copy entries you want under IaC management into your
# {{ falcon_dlp_policies_dir }}/local_application_groups/ directory.
# Application IDs have been resolved back to names from the local_applications
# table. Entries marked "# UNKNOWN_ID:..." reference an application that
# no longer exists in this tenant.
{% if _truly_system_local_app_groups | length > 0 %}
#
# System-defined local application groups ({{ _truly_system_local_app_groups | length }}) are protected and NOT exported:
{% for g in _truly_system_local_app_groups | sort(attribute='name') %}
#   - {{ g.name }}
{% endfor %}
{% endif %}

{% if _for_export_local_app_groups | length == 0 %}
falcon_dlp_local_application_groups: []
{% else %}
falcon_dlp_local_application_groups:
{% for g in _for_export_local_app_groups | sort(attribute='name') %}
  - name: {{ g.name | to_json }}
    description: {{ g.description | default('') | to_json }}
    applications:
{% for app_id in g.applications | default([]) %}
{% if app_id in (_local_apps_by_id | default({})) %}
      - {{ _local_apps_by_id[app_id] | to_json }}
{% else %}
      - {{ ('UNKNOWN_ID:' ~ app_id) | to_json }}  # orphaned reference
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
